# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SHUTDOWN_TIMEOUT=30s

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT=5s
CACHE_TTL=24h
RATE_DURATION=1m

# HTTP client (outgoing requests)
REQUEST_TIMEOUT=10s

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_MAX_AGE=86400

# Food API keys
USDA_API_KEY=your_usda_api_key
EDAMAM_APP_ID=your_edamam_app_id
EDAMAM_APP_KEY=your_edamam_app_key

# Food provider: openfoodfacts (default)
FOOD_PROVIDER=openfoodfacts
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org
OPENFOODFACTS_USER_AGENT=CalorieProxy/1.0

# Auth & DB
JWT_SECRET=your_jwt_secret
DATABASE_URL=postgres://localhost:5432/calorie?sslmode=disable
